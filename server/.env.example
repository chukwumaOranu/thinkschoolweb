NODE_ENV=production
PORT=5000
SERVER_ENV_FILE=./server/.env.production

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=thinkschool_web
DB_USER=thinkschool_web
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# JWT
JWT_ACCESS_SECRET=change-me-long-random-secret
JWT_REFRESH_SECRET=change-me-long-random-secret
JWT_ACCESS_EXPIRES=1d
JWT_REFRESH_EXPIRES=30d

# Email
EMAIL_ENABLED=true
APP_NAME=ThinkSchool App
EMAIL_PRIMARY_COLOR=#003399
EMAIL_ACCENT_COLOR=#FECE0A
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@example.com
SMTP_PASS=change-me
SMTP_FROM="ThinkSchool <info@example.com>"
CONTACT_NOTIFY_TO=info@example.com
CONTACT_ADMIN_SUBJECT_PREFIX=New ThinkSchool Enquiry
CONTACT_CONFIRMATION_SUBJECT=We received your ThinkSchool enquiry

# Frontend
CLIENT_URL=https://home.thinkschoolapp.org
CORS_ORIGINS=http://localhost:5173,https://home.thinkschoolapp.org
VITE_API_URL=https://apihome.thinkschoolapp.org

# File storage
UPLOAD_DEST=local
MAX_FILE_SIZE_MB=1000
